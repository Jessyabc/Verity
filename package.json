{
  "name": "verity-or-else",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:mobile": "npx expo start ./apps/mobile --go",
    "dev:mobile:clear": "npx expo start ./apps/mobile --go --clear",
    "dev:mobile:tunnel": "npx expo start ./apps/mobile --go --tunnel",
    "dev:mobile:tunnel:clear": "npx expo start ./apps/mobile --go --tunnel --clear",
    "dev:mobile:sim": "npx expo start ./apps/mobile --localhost --go",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:mobile": "npm run lint -w mobile",
    "preview": "vite preview",
    "monitor:once": "tsx scripts/monitor-once.ts",
    "enrich:once": "tsx scripts/enrich-documents-once.ts",
    "research:company": "tsx scripts/research-company-once.ts",
    "research:watchlist": "tsx scripts/research-watchlist-once.ts",
    "import:sec-tickers": "tsx scripts/import-sec-tickers.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.14.0",
    "robots-parser": "^3.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
