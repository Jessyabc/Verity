# Copy to `.env.local` in the repo root (preferred) or `.env` in this folder.
# Never commit real keys. `metro.config.js` loads root `.env` and `.env.local`
# so EXPO_PUBLIC_* vars can live alongside the web app keys.
# Only anon/publishable keys in this file — service role keys never go in client builds.

# ─── Supabase ──────────────────────────────────────────────────────────────────
# EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# ─── RevenueCat (in-app subscriptions) ────────────────────────────────────────
# Get this from: app.revenuecat.com → Project → iOS App → Public SDK Key
# Looks like: appl_xxxxxxxxxxxxxxxxxxxx
# EXPO_PUBLIC_REVENUECAT_API_KEY=appl_xxxxxxxxxxxxxxxxxxxx

# ─── Owner account bypass ─────────────────────────────────────────────────────
# Your own email address. Grants permanent active entitlement in dev/prod
# without consuming a real subscription. Also set in EAS secrets for production.
# Separately, grant yourself a RevenueCat Promotional Entitlement (lifetime)
# in the RC dashboard — that goes through the real code path for dogfooding.
# EXPO_PUBLIC_OWNER_EMAIL=you@yourdomain.com

# ─── Market data ──────────────────────────────────────────────────────────────
# Company profile stock quotes, market cap, P/E — https://finnhub.io (free tier)
# EXPO_PUBLIC_FINNHUB_API_KEY=your_finnhub_key

# ─── Supabase auth notes ───────────────────────────────────────────────────────
# Dashboard → Authentication → Providers → Email: keep enabled (password + magic link).
# For simulator testing: turn OFF "Confirm email" so sign-up signs in immediately.
#
# Authentication → URL configuration (Redirect URLs):
#   verity://auth-callback          ← production magic link / OAuth callback
#   exp://127.0.0.1:8081/--/auth-callback   ← Expo Go (if you use magic links there)
