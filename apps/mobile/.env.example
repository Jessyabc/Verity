# Copy to `.env` in this folder for local Expo. Never commit real keys.
# Only anon/publishable key + project URL — same idea as VITE_SUPABASE_* on web.

# EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Supabase Dashboard → Authentication → Providers → Email: keep enabled (password + magic link).
# For quick simulator testing: consider turning OFF "Confirm email" so sign-up signs in immediately.
#
# Authentication → URL configuration (magic link only):
# Add verity://auth-callback (and exp://... for Expo Go if you use magic links there).
