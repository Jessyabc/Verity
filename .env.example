# Copy to `.env.local` (and/or `.env`) for local development. Never commit real keys.
# Vite only exposes variables prefixed with `VITE_`.

# --- Supabase (dashboard → Settings → API) ---
# VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_or_anon_key

# --- Expo mobile (apps/mobile/.env — see apps/mobile/.env.example) ---
# EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# EXPO_PUBLIC_FINNHUB_API_KEY=your_finnhub_key   # optional; company profile market data (same in apps/mobile/.env)
# Do not put service role, OpenAI, or Perplexity keys in the mobile app.

# --- Server-only scripts (monitor-once, enrich-documents-once — never bundle into the client) ---
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- OpenAI (Phase 4 enrichment — npm run enrich:once) ---
# PDFs: Responses API + native PDF via file upload (no LlamaParse). Images: same model with vision.
# HTML/text: cheaper model below.
# OPENAI_API_KEY=sk-...
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_DOCUMENT_MODEL=gpt-4o
# OPENAI_VISION_MODEL=          # optional override; defaults to OPENAI_DOCUMENT_MODEL for PDFs + images
# VERITY_ENRICH_BATCH=8         # max rows per enrich:once run (default 8)

# --- Perplexity (optional — server/scripts only; do not use VITE_ prefix) ---
# https://docs.perplexity.ai — paste your API key here for upcoming search / research helpers.
# PERPLEXITY_API_KEY=pplx-...
# PERPLEXITY_MODEL=sonar         # optional; model id if you override defaults in code later
# WATCHLIST_SLUGS=microsoft,apple   # comma slugs for npm run research:watchlist & GitHub Actions (fallback)
# WATCHLIST_FROM_DB=true            # use distinct slugs from user_watchlist (apply migration); empty → WATCHLIST_SLUGS
# WEEKEND_RESEARCH=true             # only for Sat/Sun script runs / weekend workflow
# ALL_PILOT=1                       # refresh all pilot companies (scripts only)

# --- SEC company directory (npm run import:sec-tickers) ---
# Required by SEC: identify your app + contact. https://www.sec.gov/os/accessing-edgar-data
# SEC_USER_AGENT=VerityMonitor/1.0 (you@example.com)
# SEC_IMPORT_LIMIT=500   # optional cap for testing (omit for full ~10k file)
# SEC_IMPORT_OFFSET=6250 # resume after a failed run (skip already-upserted prefix)
# SEC_IMPORT_BATCH_SIZE=80 SEC_IMPORT_PAUSE_MS=300  # if Supabase closes long runs

# --- Admin (inventory Edge Function + /app/admin/inventory) ---
# Same email as Supabase Dashboard → Edge Functions → Secrets → ADMIN_EMAIL
# VITE_ADMIN_EMAIL=you@example.com

# --- Optional: future API / workers ---
# VITE_API_URL=
